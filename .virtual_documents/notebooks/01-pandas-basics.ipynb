#TOP N-товаров


import pandas as pd
Top_N_Sales = pd.read_csv(DATA_DIR / 'Top_N_Sales.csv', sep=';')
Top_N_Sales


def top(Top_N_Sales, n): 
    res = Top_N_Sales.groupby(['Item'], as_index = False)[['Quantity', 'Amount']].agg(['sum']) 
    res.columns = res.columns.droplevel(1) 
    return res.sort_values(by='Amount', ascending=False).head(n) 

top(Top_N_Sales, 5)


# Чтение CSV по абсолютному пути (Windows).
# Префикс r'...' — raw-строка, чтобы обратные слэши не интерпретировались как escape-последовательности.
# Без r пришлось бы писать 'C:\\\\Users\\\\...', что неудобно и легко ошибиться.
# Имя файла — orders.csv, НЕ orders.csv - orders.csv (такого файла нет в data/).
# Такой суффикс иногда появляется при копировании файлов через проводник Windows или при сохранении через браузер.
# Минус абсолютного пути: код не переносим между машинами/ОС.
# В этом ноутбуке основной паттерн — DATA_DIR / 'orders.csv' (см. setup-ячейку выше).
df = pd.read_csv(DATA_DIR / 'orders.csv')
df
