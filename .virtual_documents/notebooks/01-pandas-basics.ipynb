# Эта ячейка: импорт pandas + определение DATA_DIR для путей к data
import pandas as pd

# === Setup: находим путь к data/ относительно текущей рабочей директории ===
# Импортируем Path — кросс-платформенный способ работы с путями.
# В отличие от строк, Path корректно собирает / и \ на любой ОС.
from pathlib import Path

# Текущая рабочая директория (cwd = current working directory).
# Это папка, из которой запущен Jupyter / Spyder, а не обязательно папка ноутбука.
_cwd = Path.cwd()

# Ищем папку data/ на 3 уровнях относительно cwd, чтобы код работал
# из любой точки проекта:
#   1) cwd = MLOps/notebooks/  →  data/ лежит в ../data
#   2) cwd = MLOps/            →  data/ лежит в ./data
#   3) cwd = корень            →  data/ лежит в MLOps/data (../..data)
if (_cwd / 'data').exists():
    DATA_DIR = _cwd / 'data'
elif (_cwd.parent / 'data').exists():
    DATA_DIR = _cwd.parent / 'data'
else:
    DATA_DIR = _cwd.parent.parent / 'data'

# Печатаем найденный путь — при Run All сразу видно, откуда читаются CSV.
